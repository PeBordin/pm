<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AQI Signage - Perfect Centered Layout</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root { --aqi-color: #95a5a6; --bg-light: #F3F3F3; }
        * { box-sizing: border-box; font-family: 'Prompt', sans-serif; }
        body, html { margin: 0; padding: 0; width: 100%; height: 100vh; background-color: var(--bg-light); overflow: hidden; display: flex; justify-content: center; align-items: center; }
        
        .screen-container { width: 100vw; height: 100vh; position: relative; background: var(--bg-light); display: flex; flex-direction: column; align-items: center; }

        /* แถบสีด้านล่างสูง 65vh ตามที่กำหนด */
        .color-bar { 
            width: 100%; 
            height: 65vh; 
            position: absolute; 
            bottom: 0; 
            background: var(--aqi-color); 
            transition: background 1s ease-in-out; 
            z-index: 5; 
        }

        .header-text { 
            margin-top: 5vh; text-align: center; color: #000; 
            font-size: clamp(3rem, 7vw, 8.5rem); font-weight: 700; 
            z-index: 10; line-height: 1.1; 
        }

        /* Card สีขาว - ปรับการจัดวางให้กึ่งกลางสมบูรณ์ */
        .main-card { 
            width: 88%; 
            max-width: 1400px; 
            height: 48vh; 
            background: white; 
            box-shadow: 0px 20px 100px rgba(0, 0, 0, 0.15); 
            border-radius: 60px; 
            z-index: 20; 
            display: flex; 
            align-items: center; 
            justify-content: center; /* จัดกลางแนวนอน */
            gap: 4vw; /* ระยะห่างที่เหมาะสมระหว่าง Icon และ Text */
            padding: 0 40px; 
            margin-top: 3vh; 
        }

        .status-icon { 
            font-size: clamp(10rem, 22vw, 24rem); 
            filter: drop-shadow(0 20px 30px rgba(0,0,0,0.1)); 
            animation: float 4s ease-in-out infinite; 
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* จัดระเบียบกลุ่มตัวเลขให้อยู่กึ่งกลางตัวเอง */
        .aqi-info { 
            display: flex;
            flex-direction: column;
            align-items: center; /* จัดกลางเลขกับหน่วย */
            justify-content: center;
        }

        .aqi-number { 
            color: var(--aqi-color); 
            font-size: clamp(12rem, 28vw, 32rem); /* ขนาดรองรับ 3 หลัก */
            font-weight: 700; 
            line-height: 0.85; 
            margin: 0;
            padding: 0;
            transition: color 1s ease; 
        }

        .aqi-unit { 
            color: var(--aqi-color); 
            font-size: clamp(2rem, 5vw, 6rem); 
            font-weight: 700; 
            margin-top: -5px; /* ปรับช่องว่างให้พอดีกับตัวเลข */
            opacity: 0.9; 
            letter-spacing: 2px;
        }

        .status-footer { 
            position: absolute; 
            bottom: 15vh; 
            color: white; 
            font-size: clamp(4rem, 10vw, 11rem); font-weight: 700; 
            z-index: 10; text-align: center; width: 100%; 
            text-shadow: 0 5px 25px rgba(0,0,0,0.2); 
        }

        .meta-info { 
            position: absolute; 
            bottom: 5vh; 
            width: 100%; 
            text-align: center; color: rgba(255,255,255,0.95); 
            font-size: clamp(1.5rem, 2.5vw, 3rem); z-index: 10; 
            font-weight: 500; 
        }

        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
    </style>
</head>
<body>

    <div class="screen-container">
        <div class="header-text">ดัชนีคุณภาพอากาศวันนี้</div>
        
        <div class="main-card">
            <div id="status-icon" class="status-icon">⏳</div>
            <div class="aqi-info">
                <div id="aqi-value" class="aqi-number">--</div>
                <div class="aqi-unit">US-AQI</div>
            </div>
        </div>

        <div class="color-bar" id="bottom-bar"></div>
        <div id="status-text" class="status-footer">กำลังอัปเดต...</div>
        
        <div class="meta-info">
            <span id="station-display-name">Chiang Mai University</span> | <span id="current-time">00:00:00</span>
        </div>
    </div>

    <script>
        const TOKEN = '7b1855999d1e30206e4beffd05616884b1f3e716';
        const CMU_STATIONS = ['@99490', '@365722', 'chiang-mai-university', 'chiangmai'];

        function updateClock() {
            const now = new Date();
            document.getElementById('current-time').innerText = now.toLocaleTimeString('th-TH');
        }

        async function fetchAirData() {
            let dataFound = false;
            for (let station of CMU_STATIONS) {
                try {
                    const response = await fetch(`https://api.waqi.info/feed/${station}/?token=${TOKEN}&_=${new Date().getTime()}`);
                    const result = await response.json();
                    if (result.status === 'ok' && result.data && result.data.aqi > 0) {
                        updateUI(result.data.aqi);
                        dataFound = true;
                        break;
                    }
                } catch (err) { console.error(err); }
            }
            if (!dataFound) document.getElementById('status-text').innerText = "ข้อมูลไม่พร้อมใช้งาน";
        }

        function updateUI(aqi) {
            const root = document.documentElement;
            const displayAqi = Math.round(aqi);
            document.getElementById('aqi-value').innerText = displayAqi;

            let color = "", text = "", icon = "";
            if (displayAqi <= 50) { color = "#2ecc71"; text = "คุณภาพอากาศดี"; icon = "😊"; }
            else if (displayAqi <= 100) { color = "#f1c40f"; text = "อากาศปานกลาง"; icon = "🙂"; }
            else if (displayAqi <= 150) { color = "#EA7D1F"; text = "เริ่มมีผลต่อสุขภาพ"; icon = "😟"; }
            else if (displayAqi <= 200) { color = "#e74c3c"; text = "มีผลต่อสุขภาพ"; icon = "😫"; }
            else if (displayAqi <= 300) { color = "#9b59b6"; text = "มีผลต่อสุขภาพมาก"; icon = "🤢"; }
            else { color = "#7f8c8d"; text = "อันตรายรุนแรง"; icon = "💀"; }

            root.style.setProperty('--aqi-color', color);
            document.getElementById('status-text').innerText = text;
            document.getElementById('status-icon').innerText = icon;
        }

        setInterval(updateClock, 1000);
        updateClock();
        fetchAirData();
        setInterval(fetchAirData, 600000);
    </script>
</body>
</html>
